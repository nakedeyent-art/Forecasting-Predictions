generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DecisionDomain {
  BUSINESS
  INVESTMENT
  CAREER
  PURCHASE
  STRATEGY
  STARTUP
  PERSONAL
}

enum RiskTolerance {
  CONSERVATIVE
  BALANCED
  AGGRESSIVE
}

enum PredictionOutcome {
  PENDING
  TRUE
  FALSE
  VOID
}

enum DecisionStatus {
  DRAFT
  ANALYZED
  ARCHIVED
}

enum SubscriptionStatus {
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum SubscriptionPlan {
  FREE
  PRO
  TEAM
}

enum ActionStatus {
  OPEN
  DONE
  VOID
}

model User {
  id               String       @id @default(cuid())
  clerkId          String       @unique
  email            String       @unique
  name             String?
  stripeCustomerId String?      @unique
  decisions        Decision[]
  predictions      Prediction[]
  subscriptions    Subscription[]
  actionItems      ActionItem[]
  presets          UserPreset[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Decision {
  id             String            @id @default(cuid())
  userId         String
  title          String
  domain         DecisionDomain
  prompt         String
  riskTolerance  RiskTolerance     @default(BALANCED)
  timeHorizon    String
  budget         String?
  successMetric  String
  recommendation String
  confidence     Float
  evidenceScore  Float
  posterior      Float?
  prior          Float?
  likelihoodRatio Float?
  researchStatus String            @default("illustrative")
  analysisJson   Json?
  status         DecisionStatus    @default(DRAFT)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  citations      EvidenceCitation[]
  scenarios      Scenario[]
  risks          Risk[]
  simulations    SimulationRun[]
  predictions    Prediction[]
  actionItems     ActionItem[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model EvidenceCitation {
  id          String   @id @default(cuid())
  decisionId  String
  title       String
  source      String
  url         String
  sourceType  String
  confidence  Float
  direction   String   @default("neutral")
  summary     String?
  isReal      Boolean  @default(false)
  retrievedAt DateTime?
  decision    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([decisionId])
}

model Scenario {
  id          String   @id @default(cuid())
  decisionId  String
  name        String
  probability Float
  payoff      Float
  narrative   String
  decision    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([decisionId])
}

model Risk {
  id          String   @id @default(cuid())
  decisionId  String
  name        String
  probability Int
  impact      Int
  mitigation  String
  confidence  Float
  decision    Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([decisionId])
}

model SimulationRun {
  id                 String   @id @default(cuid())
  decisionId          String
  iterations          Int
  expectedValue       Float
  successProbability  Float
  p10                 Float
  p50                 Float
  p90                 Float
  lossProbability     Float?
  expectedShortfall   Float?
  decision            Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())

  @@index([decisionId])
}

model Prediction {
  id          String            @id @default(cuid())
  userId      String
  decisionId  String?
  statement   String
  probability Float
  dueDate     DateTime
  outcome     PredictionOutcome @default(PENDING)
  brierScore  Float?
  resolutionNote String?
  updates     PredictionUpdate[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  decision    Decision?         @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  resolvedAt  DateTime?

  @@index([userId, dueDate])
  @@index([decisionId])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  stripeSubscriptionId  String   @unique
  status               SubscriptionStatus
  plan                 SubscriptionPlan
  currentPeriodEnd     DateTime
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

model PredictionUpdate {
  id           String     @id @default(cuid())
  predictionId String
  probability Float
  note         String?
  prediction   Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([predictionId, createdAt])
}

model ActionItem {
  id          String       @id @default(cuid())
  userId      String
  decisionId  String?
  title       String
  owner       String
  dueDate     DateTime
  status      ActionStatus @default(OPEN)
  rationale   String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  decision    Decision?    @relation(fields: [decisionId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, status, dueDate])
  @@index([decisionId])
}

model UserPreset {
  id        String   @id @default(cuid())
  userId    String
  label     String
  request   Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}
